{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ProwlrBot/roar-protocol/spec/schemas/agent-identity.json",
  "title": "AgentIdentity",
  "description": "ROAR Layer 1: W3C DID-based agent identity. Every agent in the ROAR ecosystem has one.",
  "type": "object",
  "required": ["did", "agent_type", "version"],
  "properties": {
    "did": {
      "type": "string",
      "description": "W3C DID URI. Supports did:roar (native), did:key (multibase-encoded public key), and did:web (domain-based) methods.",
      "pattern": "^did:(roar:(agent|tool|human|ide):[a-z0-9-]+-[a-f0-9]{8,}|key:[a-zA-Z0-9._-]+|web:.+)$",
      "examples": [
        "did:roar:agent:architect-a1b2c3d4e5f6g7h8",
        "did:roar:tool:shell-executor-f5e6d7c8a9b0",
        "did:roar:human:nunu-9a8b7c6d5e4f",
        "did:roar:ide:claude-code-e1f2a3b4c5d6"
      ]
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable name (e.g., 'architect', 'frontend-dev')",
      "examples": ["architect", "frontend-dev", "shell-executor"]
    },
    "agent_type": {
      "type": "string",
      "enum": ["agent", "tool", "human", "ide"],
      "description": "Classifies what kind of entity this identity belongs to"
    },
    "capabilities": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Simple capability strings. Used for discovery search.",
      "examples": [["python", "api", "architecture"], ["code", "review", "testing"]]
    },
    "version": {
      "type": "string",
      "description": "ROAR protocol version this identity was created with",
      "default": "1.0",
      "examples": ["1.0"]
    },
    "public_key": {
      "type": ["string", "null"],
      "description": "Ed25519 public key (hex-encoded) for asymmetric message signing. Null if using HMAC-SHA256.",
      "examples": ["a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2"]
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "did": "did:roar:agent:architect-a1b2c3d4e5f6a1b2",
      "display_name": "architect",
      "agent_type": "agent",
      "capabilities": ["python", "api", "architecture"],
      "version": "1.0",
      "public_key": null
    }
  ]
}
