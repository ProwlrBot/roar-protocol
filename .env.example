# ROAR Protocol Environment Configuration
# Copy to .env and modify for your environment.

# Redis connection URL
# Development: redis://localhost:6379
# Production:  rediss://your-redis-host:6379  (TLS-enabled)
ROAR_REDIS_URL=redis://localhost:6379

# Environment: development, staging, production
ROAR_ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR
ROAR_LOG_LEVEL=DEBUG

# CORS allowed origins (comma-separated)
# NEVER use '*' in production
ROAR_ALLOWED_ORIGINS=http://localhost:3000

# HMAC signing secret for message verification
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ROAR_SIGNING_SECRET=

# Federation shared secret (required for hub-to-hub sync)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ROAR_FEDERATION_SECRET=

# Agent display name and port
ROAR_HOST_NAME=roar-server
ROAR_HOST_PORT=8000

# Rate limiting (per-IP)
ROAR_RATE_LIMIT_PER_MINUTE=100
ROAR_RATE_LIMIT_PER_HOUR=1000
